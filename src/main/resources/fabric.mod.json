{
	"schemaVersion": 1,
	"id": "minetale",
	"version": "${version}",
	"name": "Minetale",
	"description": "Adding Hytale to Minecraft",
	"authors": [
		"SMHerobrine"
	],
	"contact": {
		"homepage": "https://discord.gg/QtcjrEXKDs",
		"sources": "https://github.com/SMHerobrine/Minetale"
	},
	"license": "CC0-1.0",
	"icon": "assets/minetale/icon.png",
